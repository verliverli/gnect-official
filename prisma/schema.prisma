generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// GNECT DATABASE SCHEMA
// Privacy-first hookup web app — Multi-country
// ============================================

model User {
  id              String    @id @default(cuid())
  nickname        String    @unique
  password_hash   String
  age             Int
  country         String    @default("Qatar")  // Country — set ONCE at registration, NEVER changeable (Poland, Qatar, Saudi Arabia, UAE)
  region          String    // City/region within the user's country
  bio             String    @default("")
  height          Int?
  weight          Int?
  body_type       String    @default("Average")
  role            String    @default("Versatile")
  role_last_changed DateTime?
  region_last_changed DateTime?  // Track when region was last changed (once per 60 days, same country only)
  availability    String    @default("Not Now")
  discretion_mode Boolean   @default(false)
  secret_phrase   String?
  not_today       Boolean   @default(false)
  not_today_expires DateTime?
  is_premium      Boolean   @default(false)
  is_premium_free Boolean   @default(true)
  is_early_adopter Boolean  @default(false)
  is_admin        Boolean   @default(false)
  is_banned       Boolean   @default(false)
  banned_reason   String?
  is_banned_posting Boolean  @default(false)
  is_online       Boolean   @default(false)
  last_seen       DateTime  @default(now())
  in_app_at       DateTime?  // Last heartbeat timestamp — "In App" indicator when within 2 min
  chats_this_week Int       @default(0)
  chats_week_reset DateTime @default(now())
  not_today_count Int       @default(0)
  not_today_reset DateTime  @default(now())
  street          String?
  cucumber_size   Int?
  show_cucumber   Boolean   @default(false)
  status_text       String?
  status_gradient   String?
  status_expires_at DateTime?
  status_views      Int       @default(0)
  rating_avg      Float     @default(0)  // Average star rating (1-5)
  rating_count    Int       @default(0)  // Number of ratings received
  notification_settings String    @default("{\"messages\":true,\"community\":false,\"profileViews\":false,\"profileSaves\":false,\"quietHoursEnabled\":false,\"quietHoursStart\":\"23:00\",\"quietHoursEnd\":\"07:00\",\"discreetNotifStyle\":\"default\",\"admin_broadcast\":true}")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  token_invalidated_before DateTime?
  telegram_chat_id  String?  // Telegram chat ID for bot notifications — set when user opens bot

  photos          ProfilePhoto[]
  into_tags       IntoTag[]
  sent_messages   Message[]       @relation("SentMessages")
  chat_participant1 Chat[]        @relation("User1Chats")
  chat_participant2 Chat[]        @relation("User2Chats")
  saved_profiles  SavedProfile[]  @relation("Saver")
  saved_by        SavedProfile[]  @relation("Saved")
  reports_made    Report[]        @relation("Reporter")
  reports_received Report[]       @relation("Reported")
  blocks_made     Block[]         @relation("Blocker")
  blocks_received Block[]         @relation("Blocked")
  rate_limits     RateLimit[]
  community_posts CommunityPost[]
  community_comments PostComment[]
  community_upvotes PostUpvote[]
  community_post_reports PostReport[]
  push_subscriptions   PushSubscription[]
  notifications        Notification[]
  broadcast_acks       BroadcastAck[]
  feedbacks            Feedback[]
  error_logs           ErrorLog[]
  admin_actions        AdminActionLog[]
  support_conversations SupportConversation[]
  support_messages      SupportMessage[]
  ratings_given        UserRating[]   @relation("Rater")
  ratings_received     UserRating[]   @relation("Rated")
  group_memberships    GroupMember[]
  group_messages       GroupMessage[]
  confessions          Confession[]
  confession_reactions ConfessionReaction[]
  confession_reports   ConfessionReport[]
  hot_take_votes       HotTakeVote[]

  // Daily engagement
  login_streak       Int       @default(0)
  last_login_date    DateTime?
  longest_streak     Int       @default(0)

  @@index([nickname])
  @@index([country])
  @@index([region])
  @@index([country, region])
  @@index([role])
  @@index([availability])
  @@index([is_online])
  @@index([street])
  @@index([not_today])
  @@index([is_banned])
  @@index([is_admin])
  @@index([created_at])
}

model ProfilePhoto {
  id            String   @id @default(cuid())
  user_id       String
  catbox_url    String
  is_locked     Boolean  @default(false)
  is_face_pic   Boolean  @default(true)
  upload_order  Int      @default(1)
  uploaded_at   DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model IntoTag {
  id       String @id @default(cuid())
  user_id  String
  tag      String

  user     User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, tag])
  @@index([user_id])
  @@index([tag])
}

model Chat {
  id                String   @id @default(cuid())
  user1_id          String
  user2_id          String
  self_destruct_hours Int?    // null = off, 1/3/6/24 = timer in hours
  created_at        DateTime @default(now())
  last_message_at   DateTime @default(now())

  user1             User     @relation("User1Chats", fields: [user1_id], references: [id], onDelete: Cascade)
  user2             User     @relation("User2Chats", fields: [user2_id], references: [id], onDelete: Cascade)
  messages          Message[]

  @@unique([user1_id, user2_id])
  @@index([user1_id])
  @@index([user2_id])
  @@index([last_message_at])
}

model Message {
  id              String    @id @default(cuid())
  chat_id         String
  sender_id       String
  content         String?
  media_url       String?
  media_type      String?   // "photo" | "view_once_photo" | null
  is_view_once    Boolean   @default(false)
  view_once_duration Int?      // seconds (5 or 10) for view-once photos, default 10
  viewed          Boolean   @default(false)
  viewed_at       DateTime?
  reply_to_id     String?
  is_ghost_deleted Boolean  @default(false)
  ghost_deleted_by String?  // user_id of who ghost-deleted (null = not ghost-deleted)
  is_unsent       Boolean   @default(false)
  delivered       Boolean   @default(false)
  delivered_at    DateTime?
  sent_at         DateTime  @default(now())
  auto_delete_at  DateTime?
  hard_delete_at  DateTime?

  chat            Chat      @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender          User      @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([chat_id])
  @@index([chat_id, sent_at])
  @@index([sender_id])
  @@index([auto_delete_at])
  @@index([hard_delete_at])
}

model SavedProfile {
  id             String   @id @default(cuid())
  user_id        String
  saved_user_id  String
  created_at     DateTime @default(now())

  saver          User     @relation("Saver", fields: [user_id], references: [id], onDelete: Cascade)
  saved          User     @relation("Saved", fields: [saved_user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, saved_user_id])
  @@index([user_id])
  @@index([saved_user_id])
}

model Report {
  id              String   @id @default(cuid())
  reporter_id     String
  reported_user_id String
  reason          String   // "Fake" | "Spam" | "Underage" | "Harassment"
  description     String?
  created_at      DateTime @default(now())

  reporter        User     @relation("Reporter", fields: [reporter_id], references: [id], onDelete: Cascade)
  reported        User     @relation("Reported", fields: [reported_user_id], references: [id], onDelete: Cascade)

  @@index([reported_user_id])
  @@index([reporter_id])
}

model IPRegistration {
  id             String   @id @default(cuid())
  ip_address     String
  registered_at  DateTime @default(now())

  @@index([ip_address])
  @@index([registered_at])
}

model RateLimit {
  id               String   @id @default(cuid())
  user_id          String
  action_type      String
  action_count     Int      @default(0)
  hour_window_start DateTime @default(now())

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, action_type])
  @@index([user_id])
}

model Block {
  id             String   @id @default(cuid())
  blocker_id     String
  blocked_id     String
  created_at     DateTime @default(now())

  blocker        User     @relation("Blocker", fields: [blocker_id], references: [id], onDelete: Cascade)
  blocked        User     @relation("Blocked", fields: [blocked_id], references: [id], onDelete: Cascade)

  @@unique([blocker_id, blocked_id])
  @@index([blocker_id])
  @@index([blocked_id])
}

model AppSettings {
  id              String   @id @default("app_settings")
  is_premium_free Boolean  @default(true)
  early_adopter_count Int   @default(0)
  max_early_adopters  Int   @default(100)
  updated_at      DateTime @updatedAt
}

// ============================================
// COMMUNITY (ASK) — Phase 4
// Anonymous Reddit-style text-only posts
// ============================================

model CommunityPost {
  id              String    @id @default(cuid())
  user_id         String
  content         String
  category        String    // "SFW" | "NSFW"
  country         String    @default("Qatar")  // Auto-tagged from user's country
  region_tag      String?
  upvotes_count   Int       @default(0)
  comments_count  Int       @default(0)
  is_deleted      Boolean   @default(false)
  is_pinned       Boolean   @default(false)
  auto_delete_at  DateTime
  created_at      DateTime  @default(now())

  author          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  comments        PostComment[]
  upvotes         PostUpvote[]
  reports         PostReport[]

  @@index([user_id])
  @@index([category])
  @@index([country])
  @@index([is_deleted])
  @@index([created_at])
  @@index([upvotes_count])
  @@index([auto_delete_at])
}

model PostComment {
  id              String    @id @default(cuid())
  post_id         String
  user_id         String
  content         String
  is_deleted      Boolean   @default(false)
  auto_delete_at  DateTime
  created_at      DateTime  @default(now())

  post            CommunityPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  author          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@index([user_id])
  @@index([created_at])
  @@index([auto_delete_at])
}

model PostUpvote {
  id              String    @id @default(cuid())
  post_id         String
  user_id         String
  created_at      DateTime  @default(now())

  post            CommunityPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  voter           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([post_id, user_id])
  @@index([post_id])
  @@index([user_id])
}

model PostReport {
  id              String    @id @default(cuid())
  post_id         String
  reporter_id     String
  reason          String    // "Spam" | "Harassment" | "Underage" | "Illegal" | "Other"
  created_at      DateTime  @default(now())

  post            CommunityPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  reporter        User      @relation(fields: [reporter_id], references: [id], onDelete: Cascade)

  @@unique([post_id, reporter_id])
  @@index([post_id])
  @@index([reporter_id])
}

// ============================================
// NOTIFICATIONS + QUICK STATUS — Phase 5
// Privacy-first discreet notifications
// ============================================

model PushSubscription {
  id          String   @id @default(cuid())
  user_id     String
  endpoint    String
  p256dh      String
  auth        String
  device_info String?  // e.g. "Chrome on Android"
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, endpoint])
  @@index([user_id])
}

model Notification {
  id          String   @id @default(cuid())
  user_id     String
  type        String   // "message" | "community" | "profile_view" | "profile_save" | "admin_broadcast" | "screenshot"
  title       String
  body        String
  data        String?  // JSON string with extra data (chatId, postId, userId, broadcastId, etc.)
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, is_read])
  @@index([is_read])
  @@index([created_at])
  @@index([type])
}

model AdminBroadcast {
  id              String    @id @default(cuid())
  admin_id        String
  title           String
  message         String
  level           String    @default("info")  // "urgent" | "info"
  target_country  String?   // null = all countries — Country = Island
  target_region   String?   // null = all regions (within target_country if set)
  action_label    String?
  action_url      String?
  scheduled_at    DateTime?
  is_sent         Boolean   @default(false)
  sent_at         DateTime?
  expires_at      DateTime?
  created_at      DateTime  @default(now())

  acknowledgements BroadcastAck[]

  @@index([is_sent])
  @@index([scheduled_at])
  @@index([level])
  @@index([target_country])
  @@index([target_region])
  @@index([created_at])
}

model BroadcastAck {
  id            String   @id @default(cuid())
  broadcast_id  String
  user_id       String
  acked_at      DateTime @default(now())

  broadcast     AdminBroadcast @relation(fields: [broadcast_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([broadcast_id, user_id])
  @@index([broadcast_id])
  @@index([user_id])
}

// ============================================
// ADMIN PANEL — Phase 9
// Full admin control center for GNECT
// ============================================

// User feedback + feature requests (grouped by country/region)
model Feedback {
  id            String   @id @default(cuid())
  user_id       String
  type          String   // "feedback" | "feature_request"
  content       String
  region        String   // user's region for grouping by country
  status        String   @default("new") // "new" | "reviewed" | "planned" | "implemented"
  is_pinned     Boolean  @default(false)
  admin_notes   String?
  created_at    DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([region])
  @@index([status])
  @@index([created_at])
}

// Client-side + server-side error tracking
model ErrorLog {
  id              String    @id @default(cuid())
  error_hash      String    // hash of message+type for grouping same errors
  message         String
  type            String    // "frontend_crash" | "api_error" | "network_error" | "socket_error"
  stack_trace     String?   // truncated to first 5 lines
  screen          String?   // which component/screen (e.g. "chats-screen")
  user_id         String?   // nullable — errors can happen before login
  user_agent      String?   // simplified browser info
  count           Int       @default(1) // how many times this exact error occurred
  first_seen_at   DateTime  @default(now())
  last_seen_at    DateTime  @default(now())
  is_resolved     Boolean   @default(false)
  resolved_by     String?   // admin user_id
  resolved_at     DateTime?

  user            User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@unique([error_hash])
  @@index([type])
  @@index([is_resolved])
  @@index([last_seen_at])
  @@index([count])
}

// Audit trail of all admin actions
model AdminActionLog {
  id            String   @id @default(cuid())
  admin_id      String
  action        String   // "ban_user" | "unban_user" | "toggle_premium" | "delete_post" | "pin_post" | "dismiss_report" | etc.
  target_type   String   // "user" | "post" | "report" | "feedback" | "broadcast" | "error"
  target_id     String
  details       String?  // JSON string with extra info
  created_at    DateTime @default(now())

  admin         User     @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@index([target_type])
  @@index([created_at])
}

// ============================================
// SUPPORT DM — Batch 2 Feature
// Direct messaging between users and admin
// ============================================

model SupportConversation {
  id          String   @id @default(cuid())
  user_id     String
  subject     String   // "Account Issue" | "Bug Report" | "Safety Concern" | "Feature Request" | "Other"
  status      String   @default("open") // "open" | "replied" | "closed"
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages    SupportMessage[]

  @@index([user_id])
  @@index([status])
  @@index([updated_at])
}

model SupportMessage {
  id              String   @id @default(cuid())
  conversation_id String
  sender_id       String   // user_id or admin_id
  is_from_admin   Boolean  @default(false)
  content         String
  created_at      DateTime @default(now())

  conversation    SupportConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          User     @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@index([created_at])
}

// ============================================
// RATING SYSTEM — 5-Star Hotel Style
// Users rate people they chatted with
// Rating is anonymous — you don't know who rated you
// ============================================

model UserRating {
  id            String   @id @default(cuid())
  rater_id      String   // who gave the rating
  rated_user_id String   // who received the rating
  stars         Int       // 1-5 stars
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  rater         User     @relation("Rater", fields: [rater_id], references: [id], onDelete: Cascade)
  rated         User     @relation("Rated", fields: [rated_user_id], references: [id], onDelete: Cascade)

  @@unique([rater_id, rated_user_id])  // One rating per user pair
  @@index([rater_id])
  @@index([rated_user_id])
  @@index([stars])
}

// ============================================
// GROUP CHAT (MIXER) — Phase 4
// Region-based anonymous group chat rooms
// Text + voice notes only, auto-delete 7 days
// ============================================

model GroupRoom {
  id              String   @id @default(cuid())
  country         String   // Country name (e.g., "Qatar")
  region          String   // Region name (e.g., "Ad Dawhah (Doha)")
  name            String   // Display name (e.g., "Doha Room")
  last_message_at DateTime @default(now())
  created_at      DateTime @default(now())

  members         GroupMember[]
  messages        GroupMessage[]

  @@unique([country, region]) // One room per region per country
  @@index([country])
  @@index([last_message_at])
}

model GroupMember {
  id              String   @id @default(cuid())
  room_id         String
  user_id         String
  anonymous_name  String   // Random name like A7X, K3Z, M9F — unique per room per user
  joined_at       DateTime @default(now())
  last_read_at    DateTime @default(now())

  room            GroupRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([room_id, user_id]) // One membership per room per user
  @@unique([room_id, anonymous_name]) // Anonymous names unique per room
  @@index([room_id])
  @@index([user_id])
}

model GroupMessage {
  id              String    @id @default(cuid())
  room_id         String
  sender_id       String
  anonymous_name  String    // Snapshot of sender's anonymous name at send time
  content         String?   // Text content (null for voice notes)
  media_url       String?   // Voice note URL
  media_type      String?   // "voice_note" only
  reply_to_id     String?   // Reply to another group message
  is_unsent       Boolean   @default(false)
  sent_at         DateTime  @default(now())
  hard_delete_at  DateTime  // 7-day auto-delete

  room            GroupRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender          User      @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([room_id])
  @@index([room_id, sent_at])
  @@index([sender_id])
  @@index([hard_delete_at])
}

// ============================================
// CONFESSIONS — Phase 5
// Anonymous wild secrets — no names, no traces
// 7-day auto-delete, reactions only (no comments)
// Country-filtered, category-tagged
// ============================================

model Confession {
  id                String    @id @default(cuid())
  user_id           String
  content           String
  category          String    // "sex_stories" | "regrets" | "fantasies" | "secrets" | "coming_out"
  anonymous_alias   String    // Random like "Shadow_7X" — unique per confession
  country           String    // Auto-tagged from user's country
  reactions_summary String    @default("{}")  // JSON: {"🔥": 5, "😱": 3, "😈": 2, "💀": 1, "😍": 4}
  total_reactions   Int       @default(0)
  reports_count     Int       @default(0)
  is_deleted        Boolean   @default(false)
  is_pinned         Boolean   @default(false)
  auto_delete_at    DateTime  // 7 days from creation
  created_at        DateTime  @default(now())

  author            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reactions         ConfessionReaction[]
  reports           ConfessionReport[]

  @@index([user_id])
  @@index([category])
  @@index([country])
  @@index([is_deleted])
  @@index([created_at])
  @@index([auto_delete_at])
}

model ConfessionReaction {
  id             String   @id @default(cuid())
  confession_id  String
  user_id        String
  emoji          String   // "🔥" | "😱" | "😈" | "💀" | "😍"
  created_at     DateTime @default(now())

  confession     Confession @relation(fields: [confession_id], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([confession_id, user_id])  // One reaction per user per confession
  @@index([confession_id])
  @@index([user_id])
}

model ConfessionReport {
  id              String   @id @default(cuid())
  confession_id   String
  reporter_id     String
  reason          String   // "Spam" | "Harassment" | "Underage" | "Illegal" | "Other"
  created_at      DateTime @default(now())

  confession      Confession @relation(fields: [confession_id], references: [id], onDelete: Cascade)
  reporter        User       @relation(fields: [reporter_id], references: [id], onDelete: Cascade)

  @@unique([confession_id, reporter_id])
  @@index([confession_id])
  @@index([reporter_id])
}

// ============================================
// DAILY ENGAGEMENT — Phase 5
// Retention hooks: Daily Dare, Hot Take, Login Streak
// ============================================

model DailyDare {
  id          String   @id @default(cuid())
  text        String   // The dare text (e.g. "Send a voice note to someone new today")
  category    String   // "social" | "flirty" | "bold" | "chill"
  date        String   // "2026-06-09" format — one dare per day
  created_at  DateTime @default(now())

  @@unique([date])
}

model HotTake {
  id          String   @id @default(cuid())
  question    String   // "Sleepover or one-night stand?"
  option_a    String   // "Sleepover"
  option_b    String   // "One-night stand"
  votes_a     Int      @default(0)
  votes_b     Int      @default(0)
  date        String   // "2026-06-09" format — one hot take per day
  created_at  DateTime @default(now())

  votes       HotTakeVote[]

  @@unique([date])
}

model HotTakeVote {
  id          String   @id @default(cuid())
  hot_take_id String
  user_id     String
  choice      String   // "a" | "b"
  created_at  DateTime @default(now())

  hot_take    HotTake  @relation(fields: [hot_take_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([hot_take_id, user_id])  // One vote per user per hot take
  @@index([hot_take_id])
  @@index([user_id])
}
